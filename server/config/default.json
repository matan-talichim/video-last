{
  "editor": {
    "inputDir": "./input",
    "outputDir": "./output",
    "tempDir": "./output/temp",
    "logsDir": "./logs",
    "cleanTempAfter": true,
    "logLevel": "info"
  },
  "server": {
    "port": 3001
  },
  "upload": {
    "allowedFormats": ["mp4", "mov", "avi", "mkv", "webm", "flv", "wmv", "m4v", "3gp", "mpeg", "mpg", "ts"],
    "maxFileSize": 10737418240
  },
  "pipeline": {
    "steps": [
      {
        "name": "preprocess",
        "enabled": true,
        "description": "חילוץ אודיו, וידאו פרוקסי ופריימים מהסרטון",
        "options": {
          "audioSampleRate": 16000,
          "proxyHeight": 480,
          "proxyFps": 10,
          "frameInterval": 5
        }
      },
      {
        "name": "presenter-detection",
        "enabled": true,
        "description": "זיהוי מגיש באמצעות Silero VAD + MediaPipe"
      },
      {
        "name": "transcription",
        "enabled": true,
        "description": "תמלול באמצעות Deepgram Nova-3"
      },
      {
        "name": "merge-and-clean",
        "enabled": true,
        "description": "מיזוג תמלול, ניקוי וסינון טייקים"
      },
      {
        "name": "analyze",
        "enabled": true,
        "description": "ניתוח AI של הסרטון — hooks, מבנה, B-Roll"
      },
      {
        "name": "edit-assembly",
        "enabled": true,
        "description": "חיתוך והרכבה FFmpeg — הפקת edited.mp4"
      },
      {
        "name": "passthrough",
        "enabled": false,
        "description": "מעביר את הקובץ בלי שינוי (לבדיקת pipeline)"
      }
    ]
  },
  "ai": {
    "defaultBrain": "claude_sonnet_4_6",
    "timeout": 600000,
    "maxTokens": 4096
  },
  "analysis": {
    "timeout": 600000,
    "maxFrames": 20,
    "maxTokens": 8192
  },
  "transcription": {
    "model": "nova-3",
    "language": "he",
    "smartFormat": true,
    "utterances": true,
    "punctuate": true,
    "words": true,
    "paragraphs": true
  },
  "presenterDetection": {
    "lipThreshold": 0.25,
    "vadThreshold": 0.75,
    "buffer": 0.1,
    "pythonPath": "python3",
    "speakerVerify": true
  },
  "editAssembly": {
    "paddingStart": 0.03,
    "paddingEnd": 0.25,
    "fadeDuration": 0.03,
    "crf": 18,
    "preset": "medium",
    "audioBitrate": "192k",
    "minSegmentDuration": 0.1,
    "denoiseNoiseFloor": -20,
    "audioCrossfade": 0.06,
    "loudnormIntegrated": -16,
    "loudnormTruePeak": -1.5,
    "loudnormRange": 11
  },
  "takeSelector": {
    "enabled": true,
    "similarityThreshold": 0.70,
    "lookbackSeconds": 15,
    "scoringOverrideMargin": 0.20
  },
  "wordScorer": {
    "thresholdPresenter": 0.50,
    "thresholdReject": 0.35
  },
  "mergeAndClean": {
    "silenceThresholdMs": 800,
    "minSegmentAfterSplit": 1.5,
    "minKeepSegmentDuration": 2.0
  },
  "audioScrub": {
    "enabled": true,
    "thresholdDb": -32
  },
  "ffmpeg": {
    "path": "ffmpeg",
    "ffprobePath": "ffprobe",
    "defaultVideoCodec": "libx264",
    "defaultAudioCodec": "aac",
    "defaultPreset": "medium"
  }
}
